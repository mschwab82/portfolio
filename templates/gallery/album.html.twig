{% extends 'base.html.twig' %}

{% block title %}Gallerien{% endblock %}

{# Wird von Base üernommen #}

{% block album %}

    {% for album_1, albums_1 in items %}
        <h2>{{ album_1 }}</h2>

        {% for album_2, albums_2 in albums_1 %}
            <ul>{{ album_2 }}</ul>
                <li>{{ albums_2.ApertureFNumber }}</li>
                <li>{{ albums_2.FocalLength }}</li>
                <li>{{ albums_2.ExposureTime }}</li>
                <li>{{ albums_2.ISOSpeedRatings }}</li>
                <li>{{ albums_2.DateTimeOriginal }}</li>
                <li>{{ albums_2.Lens }}</li>       
            {% endfor %}  
        {% endfor %} 


    <section class="overflow-hidden text-gray-700">
        <div class="container px-5 py-2 mx-auto lg:pt-12 lg:px-32">
            <div class="flex flex-wrap -m-1 md:-m-2">
                {% for album, albums in items %}
                    <div class="flex flex-wrap w-1/3">
                        {% for file, files in albums %}
                            {% if loop.index == 1 %}
                                <div class="w-full p-1 md:p-2">
                                    <a href=""><img alt="gallery" class="block object-cover object-center w-full h-64 rounded-xl" src="{{ asset('images/gallery') }}/{{ album }}/{{ file }}"></a>
                                </div>
                            {% endif %}
                        {% endfor %} 
                    </div>
                {% endfor %}
            </div>
        </div>
    </selection>
{% endblock %}