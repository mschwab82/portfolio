{% extends 'base.html.twig' %}

{% block title %}Gallerien{% endblock %}

{% block nav_1 %}{% endblock %}

{% block album %}

	<div class="grid 2xl:grid-cols-5 xl:grid-cols-4 lg:grid-cols-3 sm:grid-cols-2 grid-cols-1 gap-x-6 gap-y-12 w-full mt-6">
		{% for album_1, albums_1 in items %}
			{% for album_2, albums_2 in albums_1 %}
				{% if loop.index == 1 %}
					<div>
						<img class="block h-56 rounded-lg object-cover object-center shadow-lg" src="{{ asset('images/gallery') }}/{{ album_1 }}/{{ album_2 }}" alt="{{ album_1 }}">
						<div class="flex items-center justify-between mt-3">
							<div class="text-center">
								<a href="{{ path ('gallery.album',{id: album_1}) }}" class="text-2xl text-medium">{{ album_1 }}</a>
							</div>
						</div>
					</div>
				{% endif %}
			{% endfor %}
		{% endfor %}
	</div>
	
{% endblock %}