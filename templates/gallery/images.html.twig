{% extends 'base.html.twig' %}

{% block title %}Home - {{ child }}{% endblock %}

{% block capture %}

    <nav class="flex" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3 text-4xl">
            <li class="inline-flex items-center">
                <a href="{{ path ('gallery.base') }}" class="inline-flex items-center">
                    <span class="text-gray-400 inline-flex items-center">
                        <svg class="mr-2 w-8 h-8" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"></path></svg>
                        Home
                    </span>
                </a>
            </li>
            <li aria-current="page">
                <div class="flex items-center">
                    <svg class="mr-2 w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path></svg>
                    {{ child }}
                </div>
            </li>
        </ol>
    </nav>

{% endblock %}

{% block album %}
    <section class="overflow-hidden text-gray-700">
        <div class="container px-5 py-2 mx-auto lg:pt-12 lg:px-32">
            <div class="flex flex-wrap -m-1 md:-m-2">
                {% for i in items %}
                    <div class="flex flex-wrap w-1/3">
                        <div class="w-full p-1 md:p-2">
                            <img alt="gallery" class="block object-cover object-center w-full h-64 rounded-xl" src="{{ asset('images/gallery') }}/{{ child }}/{{ i }}">
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </selection>
{% endblock %}